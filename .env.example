# ============================================================
# TAHINIS FINANCIAL PLATFORM — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# App
APP_ENV=development
APP_NAME="Tahinis Financial Platform"
DEBUG=true
LOG_LEVEL=INFO

# ---- JWT (RS256) ----
# Generate with: scripts/generate_keys.sh
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
<paste private key here>
-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
<paste public key here>
-----END PUBLIC KEY-----"

# ---- Database ----
# Docker Compose default:
DATABASE_URL=postgresql+asyncpg://tahinis:tahinis@localhost:5432/tahinis_dev
# Railway injects: DATABASE_URL (postgres:// prefix — auto-normalized in config.py)

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
# Railway injects: REDIS_URL

# ---- Object Storage (S3 / Cloudflare R2 / MinIO) ----
STORAGE_BUCKET=tahinis-docs
# Leave STORAGE_ENDPOINT_URL empty for AWS S3. Set for R2 or MinIO.
STORAGE_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# ---- Credential Encryption ----
# 32-byte base64-encoded AES key for encrypting OAuth tokens at rest
# Generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
CREDENTIAL_ENCRYPTION_KEY=<generate and paste here>

# ---- Google ----
GOOGLE_DOC_AI_PROJECT_ID=
GOOGLE_DOC_AI_LOCATION=us
GOOGLE_DOC_AI_PROCESSOR_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Microsoft (Outlook sync only) ----
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ---- Toast POS ----
TOAST_API_BASE_URL=https://ws-api.toasttab.com
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=

# ---- Virus Scanning (ClamAV) ----
# Leave CLAMAV_HOST empty to skip AV scanning in dev/test
CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_STRICT=false

# ---- Anthropic ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ---- CORS ----
# Comma-separated origins
ALLOWED_ORIGINS=["http://localhost:3000"]
